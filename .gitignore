# =====================================================
# Unified .gitignore — dotfiles / dwm / Dwmblocks / St / slock / Zed
# =====================================================

# ---------- Secrets ----------
dotfiles/**/gh/.config/hosts.yml
dotfiles/gh/.config/gh
dotfiles/gh/.config/gh/hosts.yml

# ---------- OS / editor junk ----------
.DS_Store
*.swp
*.swo
*~

# ---------- Cache, temp, logs ----------
*.log
*.tmp
*.bak
*.tar.gz
.git_history
__pycache__/
*.pyc
**/cache/
**/tmp/
**/.cache/
**/Crashpad/
**/SingletonSocket
**/SingletonLock

# ---------- App-specific ----------
dotfiles/btop/.config/btop/btop.log
dotfiles/lazygit/.config/lazygit/temp*
dotfiles/fastfetch/.config/fastfetch/*.png
dotfiles/fastfetch/.config/fastfetch/*.jpg
dotfiles/ncspot/.config/ncspot/userstate.cbor
dotfiles/scripts/.config/scripts/dwm/haiku

# Vesktop: only track themes, ignore everything else (Crashpad, session data, cookies, etc.)
dotfiles/vesktop/*
!dotfiles/vesktop/themes/

# ---------- Dwmblocks project files ----------
Dwmblocks/AGENTS.md
Dwmblocks/LICENSE
Dwmblocks/dwmblocks
Dwmblocks/README.md
Dwmblocks/Makefile
Dwmblocks/dwmblocks.c.rej
# Custom local blocks config (per-machine)
blocks.h

# =====================================================
# C build artifacts (suckless: dwm, Dwmblocks, St, slock)
# =====================================================

# Compiled binaries (match by dir since some share names with source dirs)
dwm/dwm
dwm/dwm.o
Dwmblocks/dwmblocks
St/st
St/st.o
slock/slock
slock/slock.o

# Object / prerequisite files
*.o
*.d
*.ko
*.obj
*.elf

# Linker output
*.ilk
*.map
*.exp

# Precompiled headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel module compile results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf
