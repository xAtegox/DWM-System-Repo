#!/usr/bin/env bash

# ─────────────────────────────────────────────
#  wallpaper picker — atego
# ─────────────────────────────────────────────

WALL_DIR="$HOME/Pictures/wallpaper"
WAL_LAST="$(dirname "$0")/wal_last.txt"
mapfile -t BACKENDS < <(wal --backend | tail -n +2 | sed 's/^ - //' | grep -v '^wal$')
BACKENDS=(wal "${BACKENDS[@]}")
BACKEND_IDX=0
PREVIEW_CACHE="$HOME/.cache/wal_preview_thumbs"
ZEN_THEME_DIR="$HOME/.config/zennotes/themes/wal-theme"
mkdir -p "$PREVIEW_CACHE"

# ── Refresh-only mode: reload cached colors + keyboard, no picker UI ──────────
# Usage: gif-test --refresh   (single command, e.g. from .xinitrc)
if [[ "$1" == "--refresh" ]]; then
  ln -sf ~/.cache/wal/colors.Xresources ~/.Xresources
  {
    cat ~/.cache/wal/colors.Xresources
    [ -f ~/.cache/wal/xrdb_extra ] && cat ~/.cache/wal/xrdb_extra
    [ -f ~/.cache/wal/dmenu ] && cat ~/.cache/wal/dmenu
  } >/tmp/xresources_combined.tmp
  xrdb -load /tmp/xresources_combined.tmp

  if [ -f ~/.cache/wal/sequences ]; then
    for pts in /dev/pts/*; do
      [ -w "$pts" ] && cat ~/.cache/wal/sequences >"$pts" 2>/dev/null &
    done
    wait
  fi

  if command -v kitty &>/dev/null; then
    kitty @ --to unix:/tmp/kitty set-colors --all ~/.cache/wal/colors-kitty.conf 2>/dev/null || true
  fi

  ~/Linux_Config/Zed/zed-theme-wal/generate_theme &
  if pgrep -x zed-editor >/dev/null; then
    ~/Linux_Config/Zed/zed-theme-wal/generate_theme
    pkill -x zed-editor
    sleep 0.2
    zeditor >/dev/null 2>&1 &
  fi

  exit 0
fi
# ── Spawn kitty window ────────────────────────────────────────────────────────
if [[ "$1" != "--inside" ]]; then
  read -r SCREEN_W SCREEN_H < <(
    xrandr --current | grep ' connected primary' |
      grep -oP '\d+x\d+' | head -1 | tr 'x' ' '
  )
  [ -z "$SCREEN_W" ] && SCREEN_W=1920
  [ -z "$SCREEN_H" ] && SCREEN_H=1080

  FONT_W=8
  FONT_H=16
  COLS=$((SCREEN_W * 72 / 100 / FONT_W))
  [ "$COLS" -lt 100 ] && COLS=100
  ROWS=$((SCREEN_H * 52 / 100 / FONT_H))
  [ "$ROWS" -lt 20 ] && ROWS=20
  POS_X=$(((SCREEN_W - COLS * FONT_W) / 2))
  POS_Y=$(((SCREEN_H - ROWS * FONT_H) / 2))

  SELF="$(realpath "$0")"
  WAL_SEQ="$HOME/.cache/wal/sequences"
  WAL_KITTY="$HOME/.cache/wal/colors-kitty.conf"

  KITTY_CONF="/tmp/walpicker_kitty_$$.conf"
  printf '# wal colors\n' >"$KITTY_CONF"
  [ -f "$WAL_KITTY" ] && cat "$WAL_KITTY" >>"$KITTY_CONF"
  printf 'font_size 11\n' >>"$KITTY_CONF"
  printf 'confirm_os_window_close 0\n' >>"$KITTY_CONF"
  printf 'initial_window_width %sc\n' "$COLS" >>"$KITTY_CONF"
  printf 'initial_window_height %sc\n' "$ROWS" >>"$KITTY_CONF"
  printf 'remember_window_size no\n' >>"$KITTY_CONF"
  printf 'placement_strategy top-left\n' >>"$KITTY_CONF"

  LAUNCHER="/tmp/walpicker_$$.sh"
  printf '#!/usr/bin/env bash\n' >"$LAUNCHER"
  printf '[ -f "%s" ] && cat "%s" 2>/dev/null\n' "$WAL_SEQ" "$WAL_SEQ" >>"$LAUNCHER"
  printf 'exec "%s" --inside\n' "$SELF" >>"$LAUNCHER"
  chmod +x "$LAUNCHER"

  exec kitty \
    --class "wal-picker" \
    --title "Wallpaper Picker" \
    --override "initial_window_x=${POS_X}" \
    --override "initial_window_y=${POS_Y}" \
    --config "$KITTY_CONF" \
    -e "$LAUNCHER"
fi
shift

# ── Ueberzugpp ───────────────────────────────────────────────────────────────
UB_PID_FILE="/tmp/.wal_$$"
cleanup() {
  ueberzugpp cmd -s "$SOCKET" -a exit 2>/dev/null
  rm -f "$UB_PID_FILE" /tmp/walpicker_*.sh /tmp/walpicker_kitty_*.conf 2>/dev/null
}
trap cleanup EXIT HUP INT QUIT TERM

ueberzugpp layer --no-stdin --silent --pid-file "$UB_PID_FILE" 2>/dev/null
UB_PID=$(cat "$UB_PID_FILE")
export SOCKET="/tmp/ueberzugpp-${UB_PID}.socket"

# ── DWM / environment refresh ─────────────────────────────────────────────────
refresh_dwm() {
  # Symlink and combine all Xresources, load atomically
  ln -sf ~/.cache/wal/colors.Xresources ~/.Xresources
  {
    cat ~/.cache/wal/colors.Xresources
    [ -f ~/.cache/wal/xrdb_extra ] && cat ~/.cache/wal/xrdb_extra
    [ -f ~/.cache/wal/dmenu ] && cat ~/.cache/wal/dmenu
  } >/tmp/xresources_combined.tmp
  xrdb -load /tmp/xresources_combined.tmp

  # Trigger DWM xrdb reload and refresh dwmblocks
  xdotool key super+ctrl+x
  pkill -RTMIN+8 dwmblocks 2>/dev/null || true
  pkill -RTMIN+10 dwmblocks 2>/dev/null || true

  # Apply wal sequences to all running terminals
  if [ -f ~/.cache/wal/sequences ]; then
    for pts in /dev/pts/*; do
      [ -w "$pts" ] && cat ~/.cache/wal/sequences >"$pts" 2>/dev/null &
    done
    wait
  fi

  # Reload kitty color scheme on all running instances
  if command -v kitty &>/dev/null; then
    kitty @ set-colors --all ~/.cache/wal/colors-kitty.conf 2>/dev/null || true
  fi

  # Trigger Zed Theme Reload
  ~/Linux_Config/Zed/zed-theme-wal/generate_theme &

  # Restart Zed to appy colour
  if pgrep -x zed-editor >/dev/null; then
    ~/Linux_Config/Zed/zed-theme-wal/generate_theme
    pkill -x zed-editor
    sleep 0.2
    zeditor >/dev/null 2>&1 &
  fi
}

set_static() {
  feh --bg-scale "$1"
}

# ── Color post-processing (inlined, replaces process-wal-colors) ──────────────
process_wal_colors() {
  # Args: bg_l bg_s other_l other_s [vibrant]
  python3 - "$1" "$2" "$3" "$4" "${5:-}" <<'PYEOF'
import colorsys, json, re, sys
from pathlib import Path

def hex_to_hsl(c):
    c = c.lstrip("#")
    r,g,b = (int(c[i:i+2],16)/255.0 for i in (0,2,4))
    h,l,s = colorsys.rgb_to_hls(r,g,b)
    return h,l,s

def hsl_to_hex(h,l,s):
    r,g,b = colorsys.hls_to_rgb(h,l,s)
    return "#{:02x}{:02x}{:02x}".format(int(r*255),int(g*255),int(b*255))

def enrich(c, ld, sd, vibrant):
    h,l,s = hex_to_hsl(c)
    new_l = max(0.0, min(1.0, l - ld))
    new_s = min(1.0, s*(1.0+sd)) if vibrant else min(0.8, s+sd)
    return hsl_to_hex(h, new_l, new_s)

bg_l, bg_s, other_l, other_s = (float(x) for x in sys.argv[1:5])
vibrant = sys.argv[5] == "vibrant" if len(sys.argv) > 5 else False

cache = Path.home() / ".cache" / "wal"
colors_json = cache / "colors.json"

data = json.loads(colors_json.read_text())
cmap = {}

for key, orig in data.get("colors", {}).items():
    new = enrich(orig, bg_l if key=="color0" else other_l,
                       bg_s if key=="color0" else other_s, vibrant)
    cmap[orig] = new
    data["colors"][key] = new

for key, orig in data.get("special", {}).items():
    new = enrich(orig, bg_l if key=="background" else other_l,
                       bg_s if key=="background" else other_s, vibrant)
    cmap[orig] = new
    data["special"][key] = new

colors_json.write_text(json.dumps(data, indent=2))

# Patch sequences, Xresources, vim colors
for fname in ["sequences", "colors.Xresources", "colors-wal.vim"]:
    p = cache / fname
    if p.exists():
        txt = p.read_text()
        for old, new in cmap.items():
            txt = re.sub(re.escape(old), new, txt, flags=re.IGNORECASE)
        p.write_text(txt)

# Regenerate colors.sh
sp = data.get("special", {}); co = data.get("colors", {}); wp = data.get("wallpaper","")
sh = f"""# Shell variables\nwallpaper='{wp}'\nbackground='{sp.get("background","#000000")}'\nforeground='{sp.get("foreground","#ffffff")}'\ncursor='{sp.get("cursor","#ffffff")}'\n"""
for i in range(16):
    sh += f"color{i}='{co.get(f'color{i}','#000000')}'\n"
(cache / "colors.sh").write_text(sh)

# Regenerate colors-kitty.conf
kitty = f"""foreground   {sp.get("foreground","#ffffff")}
background   {sp.get("background","#000000")}
cursor       {sp.get("cursor","#ffffff")}\n"""
pairs = [(0,8),(1,9),(2,10),(3,11),(4,12),(5,13),(6,14),(7,15)]
for a,b in pairs:
    kitty += f"color{a:<5}  {co.get(f'color{a}','#000000')}\ncolor{b:<5}  {co.get(f'color{b}','#000000')}\n"
(cache / "colors-kitty.conf").write_text(kitty)

# Process user templates
tpl_dir = Path.home() / ".config" / "wal" / "templates"
if tpl_dir.exists():
    for tpl in tpl_dir.glob("*"):
        if tpl.is_file():
            txt = tpl.read_text()
            for k,v in co.items(): txt = txt.replace(f"{{{k}}}", v)
            for k,v in sp.items(): txt = txt.replace(f"{{{k}}}", v)
            txt = txt.replace("{wallpaper}", wp)
            (cache / tpl.name).write_text(txt)
PYEOF
}

# ── Sync keyboard backlight to a darkened, saturated accent color ─────────────
sync_keyboard_color() {
  local colors_json="$HOME/.cache/wal/colors.json"
  [ -f "$colors_json" ] || return
  local accent
  accent=$(python3 -c "
import colorsys, json
from pathlib import Path
try:
    data = json.loads(Path('$colors_json').read_text())
    c = data.get('colors', {}).get('color4', '#000000').lstrip('#')
    r,g,b = (int(c[i:i+2],16)/255.0 for i in (0,2,4))
    h,l,s = colorsys.rgb_to_hls(r,g,b)
    l = 0.12  # near-dark, regardless of source lightness
    s = min(1.0, s * 1.6)        # more saturated / punchy
    r,g,b = colorsys.hls_to_rgb(h,l,s)
    print(f'{int(r*255):02x}{int(g*255):02x}{int(b*255):02x}')
except Exception:
    pass
")
  [ -n "$accent" ] || return
  asusctl -k low >/dev/null 2>&1
  asusctl aura effect static -c "$accent" >/dev/null 2>&1
}

# ── Sync ZenNotes custom theme (drop-in, hot-reloads — no app restart) ────────
sync_zennotes_theme() {
  local colors_json="$HOME/.cache/wal/colors.json"
  [ -f "$colors_json" ] || return

  python3 - "$colors_json" "$ZEN_THEME_DIR" <<'PYEOF'
import colorsys, json, sys
from pathlib import Path

colors_json, theme_dir = sys.argv[1], Path(sys.argv[2])

def hex_to_rgb(c):
    c = c.lstrip("#")
    return tuple(int(c[i:i + 2], 16) for i in (0, 2, 4))

def rgb_str(c):
    r, g, b = hex_to_rgb(c)
    return f"{r} {g} {b}"

def hex_to_hls(c):
    r, g, b = (v / 255.0 for v in hex_to_rgb(c))
    return colorsys.rgb_to_hls(r, g, b)

def shift(c, dl=0.0, ds=0.0):
    """Nudge a hex color's lightness/saturation, return as 'r g b'."""
    h, l, s = hex_to_hls(c)
    l = max(0.0, min(1.0, l + dl))
    s = max(0.0, min(1.0, s + ds))
    r, g, b = colorsys.hls_to_rgb(h, l, s)
    return f"{int(r * 255)} {int(g * 255)} {int(b * 255)}"

data = json.loads(Path(colors_json).read_text())
sp = data.get("special", {})
co = data.get("colors", {})

bg = sp.get("background", "#1c1c1e")
fg = sp.get("foreground", "#ffffff")
accent = co.get("color4", "#0a84ff")

_, l_bg, _ = hex_to_hls(bg)
dark = l_bg < 0.5
# In dark palettes, "elevated" surfaces get lighter than bg.
# In light palettes, they get darker. Same sign drives the fg/grey ramp.
sign = 1 if dark else -1

tokens = {
    "--z-bg": rgb_str(bg),
    "--z-bg-softer": shift(bg, sign * 0.02),
    "--z-bg-1": shift(bg, sign * 0.05),
    "--z-bg-2": shift(bg, sign * 0.09),
    "--z-bg-3": shift(bg, sign * 0.14),
    "--z-bg-4": shift(bg, sign * 0.24),

    "--z-fg": rgb_str(fg),
    "--z-fg-1": shift(fg, sign * 0.02),
    "--z-fg-2": shift(fg, -sign * 0.27),

    "--z-grey-2": shift(fg, -sign * 0.27),
    "--z-grey-1": shift(fg, -sign * 0.36),
    "--z-grey-0": shift(fg, -sign * 0.45),
    "--z-grey-dim": shift(fg, -sign * 0.60),

    "--z-accent": rgb_str(accent),
    "--z-accent-soft": shift(accent, sign * 0.12),
    "--z-accent-muted": shift(accent, 0.0, -0.35),

    "--z-red": rgb_str(co.get("color1", "#c14a4a")),
    "--z-green": rgb_str(co.get("color2", "#6c782e")),
    "--z-yellow": rgb_str(co.get("color3", "#b47109")),
    "--z-blue": rgb_str(co.get("color4", "#45707a")),
    "--z-purple": rgb_str(co.get("color5", "#945e80")),
    "--z-aqua": rgb_str(co.get("color6", "#4c7a5d")),

    "--z-shadow": rgb_str(bg) if dark else "17 17 19",

    "--z-glass-a1": "0.6",
    "--z-glass-a2": "0.48",
    "--z-glass-a3": "0.34",
    "--z-glass-a4": "0.24",
}

body = "\n".join(f"  {k}: {v};" for k, v in tokens.items())

css = (
    "/* Wal Theme — auto-generated by gif-test, do not edit by hand.\n"
    " * Regenerated on every wallpaper/theme change from ~/.cache/wal/colors.json */\n"
    ":root {\n"
    f"  color-scheme: {'dark' if dark else 'light'};\n"
    f"{body}\n"
    "}\n"
    ':root[data-theme-mode="dark"] {\n'
    f"{body}\n"
    "}\n"
)

theme_dir.mkdir(parents=True, exist_ok=True)
(theme_dir / "theme.css").write_text(css)

manifest_path = theme_dir / "manifest.json"
if not manifest_path.exists():
    manifest = {
        "name": "Wal Theme",
        "author": "atego",
        "version": "1.0.0",
        "description": "Auto-generated theme synced to the current pywal palette.",
        "modes": "both",
        "preview": {"light": accent, "dark": accent},
    }
    manifest_path.write_text(json.dumps(manifest, indent=2))
PYEOF
}

# ── Apply wallpaper + colors ──────────────────────────────────────────────────
apply() {
  local file="$1" backend="$2" mode="${3:-dark}"

  set_static "$file"
  case "$mode" in
  light)
    wal -i "$file" -l --backend "$backend" -t -n -q
    process_wal_colors 0.05 0.0 0.2 0.3
    ;;
  medium)
    wal -i "$file" --backend "$backend" -t -n -q
    process_wal_colors 0.0 2.0 0.02 2.0 vibrant
    ;;
  *)
    wal -i "$file" --backend "$backend" -t -n -q
    ;;
  esac

  sync_keyboard_color
  sync_zennotes_theme

  for sock in "$XDG_RUNTIME_DIR"/nvim.*.0; do
    [ -S "$sock" ] && nvim --server "$sock" --remote-send ':colorscheme wal<CR>' 2>/dev/null
  done

  refresh_dwm
  echo "$file" >"$WAL_LAST"
  notify-send "Wallpaper" "$(basename "$file") [$mode]" -t 3000
}

# ── Apply theme only (no wallpaper change) ────────────────────────────────────
apply_theme() {
  local theme="$1" mode="${2:-dark}"
  echo "$theme $mode" >"$HOME/.cache/wal/last_theme"

  case "$mode" in
  light)
    wal --theme "$theme" -l -t -n -q
    process_wal_colors 0.05 0.0 -0.15 0.3
    ;;
  medium)
    wal --theme "$theme" -t -n -q
    process_wal_colors 0.0 2.0 0.0 2.0 vibrant
    ;;
  *)
    wal --theme "$theme" -t -n -q
    ;;
  esac
  sync_keyboard_color
  sync_zennotes_theme

  refresh_dwm
  notify-send "Theme" "$theme [$mode]" -t 3000
}

# ── Theme picker (Ctrl+T) ─────────────────────────────────────────────────────
# Preview just reads colors.json — zero wal invocations, so ueberzugpp stays stable
pick_theme() {
  wal --theme 2>/dev/null |
    grep -oP '(?<=- )[\w.-]+' |
    sort |
    fzf \
      --no-sort \
      --reverse \
      --style=full \
      --border=sharp \
      --border-label=" Theme Picker " \
      --border-label-pos=2 \
      --no-scrollbar \
      --padding="0,0" \
      --prompt=" λ " \
      --pointer="▌" \
      --marker="●" \
      --input-label=" search " \
      --preview-label=" [mode: $MODE]  ctrl-l:cycle mode  esc:back " \
      --preview-border=sharp \
      --info=right \
      --color="bg:-1,bg+:#161916,fg:#888880,fg+:#c0c0ba" \
      --color="hl:#6a7d5e,hl+:#8aaa74" \
      --color="border:#333630,preview-border:#333630" \
      --color="prompt:#8aaa74,pointer:#8aaa74,marker:#6a7d5e" \
      --color="input-label:#3a4436,preview-label:#3a4436,label:#3a4436" \
      --color="info:#3a4436,spinner:#8aaa74" \
      --preview="
        theme={};
        # Apply theme quietly so colors.json is fresh for the swatch
        wal --theme \"\$theme\" -t -n -q 2>/dev/null;
        # Print 16-color ANSI swatch from updated colors.json — no ueberzugpp, no ffmpeg
        python3 -c \"
import json, sys
from pathlib import Path
try:
    data = json.loads(Path('$HOME/.cache/wal/colors.json').read_text())
    sp   = data.get('special', {})
    cols = list(data.get('colors', {}).values())
    bg   = sp.get('background', '#000000')
    fg   = sp.get('foreground', '#ffffff')

    def hex_block(c, label=''):
        r,g,b = int(c[1:3],16),int(c[3:5],16),int(c[5:7],16)
        lum = 0.299*r + 0.587*g + 0.114*b
        tc  = '0;0;0' if lum > 140 else '255;255;255'
        return f'\033[48;2;{r};{g};{b}m\033[38;2;{tc}m {c} \033[0m'

    print()
    print('  special')
    print('  ' + hex_block(bg, 'bg') + '  background')
    print('  ' + hex_block(fg, 'fg') + '  foreground')
    print()
    print('  colors')
    for i, c in enumerate(cols[:8]):
        c2 = cols[i+8] if i+8 < len(cols) else c
        print(f'  {hex_block(c)}  color{i:<2}    {hex_block(c2)}  color{i+8}')
    print()
except Exception as e:
    print('no colors.json yet')
\" 2>/dev/null
      " \
      --preview-window="right:55%:nowrap" \
      --bind="ctrl-l:become(echo __TOGGLE_MODE__)" \
      --bind="esc:become(echo __BACK__)"
}

export SOCKET PREVIEW_CACHE

# ── Main loop ─────────────────────────────────────────────────────────────────
MODE="dark"

while true; do
  BACKEND="${BACKENDS[$BACKEND_IDX]}"
  PLABEL=" ${BACKEND}  [${MODE}]  ctrl-b:backend  ctrl-l:mode  ctrl-t:theme  ctrl-r:random  esc:quit "

  IMG=$(
    find -L "$WALL_DIR" -type f \( \
      -iname "*.jpg" -o -iname "*.png" -o -iname "*.jpeg" \
      \) | sort | while IFS= read -r f; do printf '%s\t%s\n' "$f" "$(basename "$f")"; done | fzf \
      --no-sort \
      --reverse \
      --style=full \
      --border=sharp \
      --border-label=" Wallpaper Picker " \
      --border-label-pos=2 \
      --no-scrollbar \
      --padding="0,0" \
      --prompt=" λ " \
      --pointer="▌" \
      --marker="●" \
      --input-label=" search " \
      --preview-label="$PLABEL" \
      --preview-border=sharp \
      --info=right \
      --delimiter='\t' \
      --with-nth=2 \
      --color="bg:-1,bg+:#161916,fg:#888880,fg+:#c0c0ba" \
      --color="hl:#6a7d5e,hl+:#8aaa74" \
      --color="border:#333630,preview-border:#333630" \
      --color="prompt:#8aaa74,pointer:#8aaa74,marker:#6a7d5e" \
      --color="input-label:#3a4436,preview-label:#3a4436,label:#3a4436" \
      --color="info:#3a4436,spinner:#8aaa74" \
      --preview="
        file={1};
        ueberzugpp cmd -s \"$SOCKET\" -i walpreview -a add \
          -x \$(( FZF_PREVIEW_LEFT + 4 )) \
          -y \$(( FZF_PREVIEW_TOP + 1 )) \
          --max-width 56 \
          --max-height 15 \
          -f \"\$file\" 2>/dev/null
      " \
      --preview-window="right:55%:nowrap" \
      --bind="ctrl-b:become(echo __NEXT_BACKEND__)" \
      --bind="ctrl-l:become(echo __NEXT_MODE__)" \
      --bind="ctrl-t:become(echo __THEME_PICKER__)" \
      --bind="ctrl-r:become(echo __RANDOM__)" \
      --bind="esc:become(echo __QUIT__)" |
      cut -f1
  )

  case "$IMG" in
  __QUIT__ | "") exit 0 ;;

  __NEXT_BACKEND__)
    BACKEND_IDX=$(((BACKEND_IDX + 1) % ${#BACKENDS[@]}))
    continue
    ;;

  __NEXT_MODE__)
    case "$MODE" in
    dark) MODE="light" ;;
    light) MODE="medium" ;;
    medium) MODE="dark" ;;
    esac
    notify-send "Wallpaper Picker" "Mode → $MODE" -t 1200
    continue
    ;;

  __THEME_PICKER__)
    THEME=$(pick_theme)
    case "$THEME" in
    "" | __BACK__)
      continue
      ;;
    __TOGGLE_MODE__)
      case "$MODE" in
      dark) MODE="light" ;;
      light) MODE="medium" ;;
      medium) MODE="dark" ;;
      esac
      notify-send "Wallpaper Picker" "Mode → $MODE" -t 1200
      continue
      ;;
    *)
      apply_theme "$THEME" "$MODE"
      exit 0
      ;;
    esac
    ;;

  __RANDOM__)
    IMG=$(find -L "$WALL_DIR" -type f \( \
      -iname "*.jpg" -o -iname "*.png" -o -iname "*.jpeg" \
      \) | shuf -n 1)
    apply "$IMG" "$BACKEND" "$MODE"
    exit 0
    ;;

  *)
    apply "$IMG" "$BACKEND" "$MODE"
    exit 0
    ;;
  esac
done
