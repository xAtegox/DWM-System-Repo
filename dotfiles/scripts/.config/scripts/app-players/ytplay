#!/usr/bin/env bash
export PATH="/usr/local/bin:$PATH"
# ytplay - Interactive YouTube search and player (similar to ani-cli)
# Usage: Launch from dwm keybind in a floating terminal
#        ytplay [optional search query]

# Config
YTDLP="yt-dlp"
MPV="mpv"
FZF="fzf"
SEARCH_SIZE=100

# Helper functions
die() {
  printf "\033[1;31mError: %s\033[0m\n" "$*" >&2
  read -p "Press Enter to exit..."
  exit 1
}

msg() {
  printf "\033[1;32m> %s\033[0m\n" "$*"
}

# Check dependencies
command -v "$YTDLP" >/dev/null 2>&1 || die "yt-dlp not found."
command -v "$MPV" >/dev/null 2>&1 || die "mpv not found."
command -v "$FZF" >/dev/null 2>&1 || die "fzf not found."

# Get search query
if [ "$#" -gt 0 ]; then
  query="$*"
else
  printf "\033[1;36mYouTube Search: \033[0m"
  read -r query
fi

[ -z "$query" ] && exit 0

# Search YouTube
msg "Searching for: \033[1;33m${query}\033[0m"
printf "\n"

# Fetch results with --flat-playlist for speed
# Fetch results with a modern User-Agent to bypass 403 blocks
results_raw=$($YTDLP --user-agent "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36" \
  "ytsearch${SEARCH_SIZE}:${query}" \
  --flat-playlist \
  --print "%(title)s|%(id)s|%(uploader)s" \
  2>/dev/null)

if [ -z "$results_raw" ]; then
  die "No results found for: $query"
fi

# Build fzf menu by processing line by line into a temp file
fzf_input_file=$(mktemp)
counter=1
while IFS='|' read -r title id uploader; do
  [ -z "$title" ] || [ -z "$id" ] && continue

  # Truncate title if too long
  if [ ${#title} -gt 80 ]; then
    title="${title:0:77}..."
  fi
  printf "%2d) %-85s (%s)\n" "$counter" "$title" "$uploader" >>"$fzf_input_file"
  counter=$((counter + 1))
done <<<"$results_raw"

if [ ! -s "$fzf_input_file" ]; then
  rm -f "$fzf_input_file"
  die "No valid results found"
fi

# Let user pick with fzf
selection=$(cat "$fzf_input_file" |
  $FZF --ansi \
    --reverse \
    --cycle \
    --header="Select video (ESC to quit, ENTER to play)" \
    --prompt="YouTube > " \
    --height=100%)

rm -f "$fzf_input_file"

[ -z "$selection" ] && exit 0

# Extract the line number from selection
line_num=$(printf "%s" "$selection" | awk '{print $1}' | tr -d ')')

# Get the corresponding video ID and title from the original results
video_line=$(printf "%s" "$results_raw" | sed -n "${line_num}p")
video_id=$(printf "%s" "$video_line" | cut -d'|' -f2)
video_title=$(printf "%s" "$video_line" | cut -d'|' -f1)

[ -z "$video_id" ] && die "Failed to extract video ID"

url="https://www.youtube.com/watch?v=${video_id}"

# Show what we're playing
clear
printf "\n"
msg "Playing: \033[1;33m${video_title}\033[0m"
printf "\n"

# Create a detached mpv process using proper daemonization
# First redirect all I/O, then use setsid to create new session
{
  setsid $MPV "$url" \
    --no-fullscreen \
    --fs=no \
    --geometry=1366x768 \
    --force-window=immediate \
    --title="$video_title" \
    --x11-name=mpv \
    --keep-open=no \
    --ytdl-format="bestvideo[height<=1080]+bestaudio/best[height<=1080]" \
    --cache=yes \
    --cache-secs=150 \
    --demuxer-max-bytes=2048M \
    --demuxer-max-back-bytes=1024M \
    --network-timeout=60 \
    --demuxer-readahead-secs=20 \
    </dev/null &>/dev/null &
} &

# Give mpv a moment to spawn window before terminal closes
sleep 0.5
exit 0
