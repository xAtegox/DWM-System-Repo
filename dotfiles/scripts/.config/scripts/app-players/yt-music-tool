#!/usr/bin/env bash

# ─────────────────────────────────────────────
#  app launcher — atego
# ─────────────────────────────────────────────

MUSIC_DIR="$HOME/Music"

# ── Spawn kitty window ────────────────────────────────────────────────────────
if [[ "$1" != "--inside" ]]; then
  read -r SCREEN_W SCREEN_H < <(
    xrandr --current | grep ' connected primary' |
      grep -oP '\d+x\d+' | head -1 | tr 'x' ' '
  )
  [ -z "$SCREEN_W" ] && SCREEN_W=1920
  [ -z "$SCREEN_H" ] && SCREEN_H=1080

  WIN_W=53
  WIN_H=12
  FONT_W=8
  FONT_H=16
  POS_X=$(((SCREEN_W - WIN_W * FONT_W) / 2))
  POS_Y=$(((SCREEN_H - WIN_H * FONT_H) / 2))

  SELF="$(realpath "$0")"
  WAL_KITTY="$HOME/.cache/wal/colors-kitty.conf"
  KITTY_CONF="/tmp/applauncher_kitty_$$.conf"

  printf '# app-launcher\n' >"$KITTY_CONF"
  [ -f "$WAL_KITTY" ] && cat "$WAL_KITTY" >>"$KITTY_CONF"
  printf 'font_family Iosevka Nerd Font\n' >>"$KITTY_CONF"
  printf 'font_size 12\n' >>"$KITTY_CONF"
  printf 'confirm_os_window_close 0\n' >>"$KITTY_CONF"
  printf 'remember_window_size no\n' >>"$KITTY_CONF"
  printf 'initial_window_width %sc\n' "$WIN_W" >>"$KITTY_CONF"
  printf 'initial_window_height %sc\n' "$WIN_H" >>"$KITTY_CONF"

  exec kitty \
    --class "app-launcher" \
    --title "App Launcher" \
    --override "initial_window_x=${POS_X}" \
    --override "initial_window_y=${POS_Y}" \
    --config "$KITTY_CONF" \
    -e "$SELF" --inside

  rm -f "$KITTY_CONF"
fi
shift

# ── Menu ──────────────────────────────────────────────────────────────────────
menu() {
  printf '  download mp3\n  change metadata\n' | fzf \
    --no-sort \
    --reverse \
    --style=full \
    --border=sharp \
    --border-label="─── music ───" \
    --border-label-pos=2 \
    --no-scrollbar \
    --no-info \
    --no-preview \
    --height=100% \
    --prompt=" ❯ " \
    --pointer="▌" \
    --padding="0,1" \
    --color="bg:-1,bg+:#0d0f0b,fg:#4a4d44,fg+:#d8d8d0" \
    --color="hl:#6a7d5e,hl+:#8aaa74" \
    --color="border:#222520" \
    --color="prompt:#8aaa74,pointer:#8aaa74,label:#2a3028" \
    --bind="esc:abort"
}

# ── Metadata editor ───────────────────────────────────────────────────────────
get_tag() {
  ffprobe -loglevel error -show_entries format_tags="$1" \
    -of default=noprint_wrappers=1:nokey=1 "$2" 2>/dev/null
}

choose_cover() {
  find "$HOME/Downloads" "$HOME/Pictures" -maxdepth 2 -type f \
    \( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" \) 2>/dev/null |
    fzf \
      --no-sort --reverse \
      --style=full \
      --border=sharp \
      --border-label=" cover image " \
      --no-scrollbar \
      --no-preview \
      --prompt=" λ " \
      --pointer="▌" \
      --padding="0,0" \
      --color="bg:-1,bg+:#1a1a1a,fg:#666660,fg+:#c8c8c4" \
      --color="hl:#888880,hl+:#d0d0cc" \
      --color="border:#2a2a2a" \
      --color="prompt:#a0a09c,pointer:#c0c0bc,label:#444440" \
      --bind="esc:abort"
}

edit_metadata() {
  local file="$1"
  clear

  local cur_artist
  cur_artist=$(get_tag "artist" "$file")
  local cur_title
  cur_title=$(get_tag "title" "$file")
  local cur_album
  cur_album=$(get_tag "album" "$file")

  printf '\033[2m  ────────────────────────────────────────\033[0m\n'
  printf '  \033[1m%s\033[0m\n' "$(basename "$file")"
  printf '\033[2m  ────────────────────────────────────────\033[0m\n\n'
  printf '  \033[2martist\033[0m  %s\n' "${cur_artist:-—}"
  printf '  \033[2mtitle\033[0m   %s\n' "${cur_title:-—}"
  printf '  \033[2malbum\033[0m   %s\n\n' "${cur_album:-—}"
  printf '\033[2m  ────────────────────────────────────────\033[0m\n'
  printf '  leave blank to keep current\n\n'

  printf '  \033[37martist\033[0m [%s]: ' "$cur_artist"
  read -r new_artist
  [ -z "$new_artist" ] && new_artist="$cur_artist"
  printf '  \033[37mtitle\033[0m  [%s]: ' "$cur_title"
  read -r new_title
  [ -z "$new_title" ] && new_title="$cur_title"
  printf '  \033[37malbum\033[0m  [%s]: ' "$cur_album"
  read -r new_album
  [ -z "$new_album" ] && new_album="$cur_album"

  printf '\n  update cover art? [y/N]: '
  read -r update_img
  local cover_path=""
  [[ "$update_img" =~ ^[Yy]$ ]] && cover_path=$(choose_cover)

  local tmp_file="${file}.tmp.mp3"
  printf '\n  \033[1;37mapplying…\033[0m\n'

  if [ -n "$cover_path" ]; then
    ffmpeg -loglevel error -y -i "$file" -i "$cover_path" \
      -map 0:a -map 1:v -c copy -id3v2_version 3 \
      -metadata:s:v title="Album cover" \
      -metadata:s:v comment="Cover (Front)" \
      -disposition:v:0 attached_pic \
      -metadata artist="$new_artist" \
      -metadata title="$new_title" \
      -metadata album="$new_album" \
      "$tmp_file"
  else
    ffmpeg -loglevel error -y -i "$file" \
      -metadata artist="$new_artist" \
      -metadata title="$new_title" \
      -metadata album="$new_album" \
      -codec copy "$tmp_file"
  fi

  if [ $? -eq 0 ]; then
    mv "$tmp_file" "$file"
    printf '  \033[1;37m  done.\033[0m\n'
  else
    printf '  \033[1;33m  failed.\033[0m\n'
    rm -f "$tmp_file"
  fi
  sleep 1
}

run_metadata() {
  while true; do
    cd "$MUSIC_DIR" || exit 1
    selection=$(find . -maxdepth 2 -type f -name "*.mp3" | sed 's|^\./||' | sort | fzf \
      --no-sort --reverse \
      --style=full \
      --border=sharp \
      --border-label=" Music Tagger " \
      --border-label-pos=2 \
      --no-scrollbar \
      --no-preview \
      --prompt=" λ " \
      --pointer="▌" \
      --marker="●" \
      --input-label=" search " \
      --info=right \
      --padding="0,0" \
      --color="bg:-1,bg+:#1a1a1a,fg:#666660,fg+:#c8c8c4" \
      --color="hl:#888880,hl+:#d0d0cc" \
      --color="border:#2a2a2a" \
      --color="prompt:#a0a09c,pointer:#c0c0bc,marker:#888880" \
      --color="input-label:#444440,label:#444440" \
      --color="info:#444440,spinner:#888880" \
      --bind="esc:abort")
    [ -z "$selection" ] && return
    edit_metadata "$MUSIC_DIR/$selection"
  done
}

# ── MP3 downloader ────────────────────────────────────────────────────────────
run_downloader() {
  while true; do
    clear
    printf '\033[2m  ──────────────────────────────────────────────────\033[0m\n'
    printf '    mp3 downloader\n'
    printf '\033[2m  ──────────────────────────────────────────────────\033[0m\n\n'
    printf '  supports: youtube  spotify  soundcloud  bandcamp\n'
    printf '  output:   %s\n\n' "$MUSIC_DIR"
    printf '\033[2m  ──────────────────────────────────────────────────\033[0m\n\n'
    printf '  paste url (q to quit): '
    read -r url

    [ -z "$url" ] && continue
    [ "$url" = "q" ] || [ "$url" = "Q" ] && return

    printf '\n'
    if [[ "$url" == *"spotify"* ]] && command -v spotdl &>/dev/null; then
      printf '\033[2m  using spotdl…\033[0m\n\n'
      spotdl "$url" --output "$MUSIC_DIR/{title}.{ext}"
    else
      printf '\033[2m  downloading…\033[0m\n\n'
      yt-dlp \
        --extract-audio \
        --audio-format mp3 \
        --audio-quality 0 \
        --embed-thumbnail \
        --embed-metadata \
        --output "$MUSIC_DIR/%(title)s.%(ext)s" \
        "$url"
    fi

    if [ $? -eq 0 ]; then
      printf '\n  \033[1;37m  done.\033[0m\n'
    else
      printf '\n  \033[1;33m  something went wrong.\033[0m\n'
    fi

    printf '\n  press enter for another, q to quit: '
    read -r again
    [ "$again" = "q" ] || [ "$again" = "Q" ] && return
  done
}

# ── Main ──────────────────────────────────────────────────────────────────────
choice=$(menu)
case "$choice" in
*download*) run_downloader ;;
*metadata*) run_metadata ;;
esac
