#!/usr/bin/env bash

export DISPLAY=:0

# Load pywal colors for fzf
[ -f ~/.cache/wal/colors.sh ] && . ~/.cache/wal/colors.sh && export FZF_DEFAULT_OPTS

# Calculate center position for 1366x768
SCREEN_W=2000
SCREEN_H=1800
TERM_W=$((180 * 8))
TERM_H=$((80 * 14))

# Center math: (Screen - Term) / 2
OFFSET_X=$(((SCREEN_W - TERM_W) / 2))
OFFSET_Y=$(((SCREEN_H - TERM_H) / 2))

# Ensure offsets aren't negative
[ $OFFSET_X -lt 0 ] && OFFSET_X=0
[ $OFFSET_Y -lt 0 ] && OFFSET_Y=0

# Launch st with adjusted geometry
st -f 'Liberation Mono:pixelsize=14' \
  -c fzfmenu \
  -n fzfmenu \
  -T fzf \
  -g "160x30+${OFFSET_X}+${OFFSET_Y}" \
  -e sh -c 'cat ~/.cache/wal/sequences 2>/dev/null; exec /home/atego/.config/scripts/app-players/ytplay'
