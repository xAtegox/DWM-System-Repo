#!/bin/bash
# Toggle picom window transparency for kitty and st terminals
# Toggles between 100% (opaque) and 85% (transparent)

if ! pgrep -x "picom" >/dev/null; then
  exit 1
fi

# Collect all kitty and st windows
kitty_windows=$(xdotool search --class "kitty" 2>/dev/null)
st_windows=$(xdotool search --class "st-256color" 2>/dev/null)
all_windows=$(printf "%s\n%s" "$kitty_windows" "$st_windows" | grep -v '^$')

if [ -z "$all_windows" ]; then
  exit 1
fi

# Check current opacity from the first available window
first_window=$(echo "$all_windows" | head -1)
current_opacity=$(xprop -id "$first_window" _NET_WM_WINDOW_OPACITY 2>/dev/null | grep -oE '[0-9]+$')

if [ -z "$current_opacity" ] || [ "$current_opacity" -gt 3865470976 ]; then
  opacity_uint32=$((75 * 42949672))
else
  opacity_uint32=$((100 * 42949672))
fi

# Apply to all windows
echo "$all_windows" | while read -r window_id; do
  xprop -id "$window_id" -f _NET_WM_WINDOW_OPACITY 32c -set _NET_WM_WINDOW_OPACITY "$opacity_uint32" 2>/dev/null
done
