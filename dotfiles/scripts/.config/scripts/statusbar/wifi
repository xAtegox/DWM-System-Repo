#!/bin/sh

TERMINAL=${TERMINAL:-st}

# Try to get wifi info using nmcli first (most reliable)
if command -v nmcli >/dev/null 2>&1; then
	# Single nmcli call with timeout (avoids stalling dwmblocks)
	LINE=$(timeout 1 nmcli -t -f ACTIVE,SSID,SIGNAL dev wifi list --rescan no 2>/dev/null | awk -F: '$1=="yes"{print; exit}')

	if [ -z "$LINE" ]; then
		echo "ůįą≠"
		exit 0
	fi

	SSID=$(echo "$LINE" | awk -F: '{print $2}')
	SIGNAL=$(echo "$LINE" | awk -F: '{print $3}')

	# Determine wifi icon based on signal strength
	if [ -n "$SIGNAL" ]; then
		if [ "$SIGNAL" -ge 80 ]; then
			ICON="ůį§®"
		elif [ "$SIGNAL" -ge 60 ]; then
			ICON="ůį§•"
		elif [ "$SIGNAL" -ge 40 ]; then
			ICON="ůį§Ę"
		else
			ICON="ůį§ü"
		fi
	else
		ICON="ůį§•"
	fi

	echo "$ICON $SSID"
else
	# Fallback to iw if nmcli is not available
	WIFI_INTERFACE=$(timeout 1 iw dev 2>/dev/null | grep "Interface" | awk '{print $2}' | head -1)
	
	if [ -z "$WIFI_INTERFACE" ]; then
		echo "ůį§≠"
		exit 0
	fi
	
	# Check connection status - single iw call
	IW_OUTPUT=$(timeout 1 iw dev "$WIFI_INTERFACE" link 2>/dev/null)
	SSID=$(echo "$IW_OUTPUT" | grep "SSID:" | awk '{print $NF}')
	SIGNAL=$(echo "$IW_OUTPUT" | grep "signal:" | awk '{print $2}' | sed 's/,//')
	
	if [ -z "$SSID" ]; then
		echo "ůį§≠"
		exit 0
	fi
	
	# Determine wifi icon based on signal strength (iw gives negative dBm values)
	if [ -n "$SIGNAL" ]; then
		# Convert negative dBm to percentage (-30 = 100%, -90 = 0%)
		PERCENT=$((100 + SIGNAL))
		if [ "$PERCENT" -ge 80 ]; then
			ICON="ůį§®"
		elif [ "$PERCENT" -ge 60 ]; then
			ICON="ůį§•"
		elif [ "$PERCENT" -ge 40 ]; then
			ICON="ůį§Ę"
		else
			ICON="ůį§ü"
		fi
	else
		ICON="ůį§•"
	fi
	
	echo "$ICON $SSID"
fi

case $BLOCK_BUTTON in
	1) setsid -f "$TERMINAL" -e nmtui ;;
	3) nmcli radio wifi toggle ;;
esac
