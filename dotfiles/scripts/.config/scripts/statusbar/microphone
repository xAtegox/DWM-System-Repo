#!/usr/bin/env bash
# Mic usage indicator for dwmblocks

# Check if any application currently has an active recording stream
IN_USE=$(pactl list source-outputs | grep -c "Source Output")

if [ "$IN_USE" -eq 0 ]; then
  echo ""
  exit 0
fi

MUTED=$(pactl get-source-mute @DEFAULT_SOURCE@ | grep -c "yes")

if [ "$MUTED" -eq 1 ]; then
  ICON="󰍭" # muted mic
else
  ICON="󰍬" # active mic
fi

echo "$ICON"

# Click handler: left click toggles mute
case $BLOCK_BUTTON in
1) pactl set-source-mute @DEFAULT_SOURCE@ toggle ;;
esac
